{
  "entities": {
    "settings": {
      "title": "System Settings",
      "description": "WordPress and Google Search Console integration settings.",
      "type": "object",
      "properties": {
        "wpUrl": { "type": "string" },
        "wpUsername": { "type": "string" },
        "wpAppPassword": { "type": "string" },
        "gscProperty": { "type": "string" },
        "sopKeywords": { "type": "array", "items": { "type": "string" } },
        "includeFaqs": { "type": "boolean" },
        "aiModel": { "type": "string" },
        "theme": { "type": "string", "enum": ["light", "dark"] },
        "openaiKey": { "type": "string" },
        "anthropicKey": { "type": "string" },
        "prompts": {
          "type": "object",
          "properties": {
            "title": { "type": "string" },
            "introduction": { "type": "string" },
            "mainContent": { "type": "string" },
            "faq": { "type": "string" },
            "conclusion": { "type": "string" }
          }
        },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["wpUrl", "wpUsername", "wpAppPassword"]
    },
    "competitor": {
      "title": "Competitor Analysis",
      "description": "Data scraped from competitor websites.",
      "type": "object",
      "properties": {
        "url": { "type": "string" },
        "wordCount": { "type": "integer" },
        "imageCount": { "type": "integer" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "authorId": { "type": "string" }
      },
      "required": ["url", "wordCount", "imageCount", "authorId"]
    },
    "post": {
      "title": "Blog Post",
      "description": "Generated and published blog posts.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "introduction": { "type": "string" },
        "mainContent": { "type": "string" },
        "conclusion": { "type": "string" },
        "faq": { "type": "string" },
        "status": { "type": "string", "enum": ["draft", "published", "scheduled"] },
        "wpId": { "type": "integer" },
        "authorId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "status", "authorId"]
    },
    "draft": {
      "title": "Post Draft",
      "description": "Autosaved drafts of blog posts.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "introduction": { "type": "string" },
        "mainContent": { "type": "string" },
        "conclusion": { "type": "string" },
        "faq": { "type": "string" },
        "status": { "type": "string", "enum": ["draft", "published", "scheduled"] },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    },
    "search": {
      "title": "Search Query",
      "description": "Historical search queries performed by the user.",
      "type": "object",
      "properties": {
        "query": { "type": "string" },
        "authorId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["query", "authorId"]
    },
    "blueprint": {
      "title": "SOP Blueprint",
      "description": "Saved writing protocols and configurations.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "name": { "type": "string" },
        "sopModels": { "$ref": "#/entities/settings/properties/sopModels" },
        "prompts": { "$ref": "#/entities/settings/properties/prompts" },
        "targetWordCount": { "type": "integer" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "name", "sopModels", "prompts"]
    }
  },
  "firestore": {
    "/settings/{userId}": {
      "schema": "settings",
      "description": "User-specific application settings"
    },
    "/blueprints/{blueprintId}": {
      "schema": "blueprint",
      "description": "User-saved writing protocols"
    },
    "/competitors/{competitorId}": {
      "schema": "competitor",
      "description": "Global or user-specific competitor research data"
    },
    "/posts/{postId}": {
      "schema": "post",
      "description": "Blog posts generated by the user"
    },
    "/drafts/{userId}": {
      "schema": "draft",
      "description": "User's current autosaved work"
    },
    "/searches/{searchId}": {
      "schema": "search",
      "description": "User's historical search queries"
    },
    "/draft_images/{imageId}": {
      "schema": {
        "title": "Draft Image",
        "type": "object",
        "properties": {
          "url": { "type": "string" },
          "prompt": { "type": "string" },
          "alt": { "type": "string" },
          "updatedAt": { "type": "string", "format": "date-time" }
        }
      },
      "description": "Fragmented image assets for drafts to avoid Firestore document size limits."
    },
    "/post_images/{imageId}": {
      "schema": {
        "title": "Post Image",
        "type": "object",
        "properties": {
          "url": { "type": "string" },
          "prompt": { "type": "string" },
          "alt": { "type": "string" },
          "updatedAt": { "type": "string", "format": "date-time" }
        }
      },
      "description": "Fragmented image assets for historical posts."
    }
  }
}
